diff --unified --recursive --new-file uClinux-2.4.x/include/asm-armnommu/arch-av3xx/time.h uClinux-2.4.x-av3xx/include/asm-armnommu/arch-av3xx/time.h
--- uClinux-2.4.x/include/asm-armnommu/arch-av3xx/time.h	1970-01-01 00:00:00.000000000 +0000
+++ uClinux-2.4.x-av3xx/include/asm-armnommu/arch-av3xx/time.h	2004-04-30 15:23:20.000000000 +0000
@@ -0,0 +1,66 @@
+/*
+ * linux/include/asm-arm/arch-av3xx/time.h
+ * based on dsc21
+ *
+ * Copyright (C) 1998 Deborah Wallach.
+ * Twiddles  (C) 1999 	Hugo Fiennes <hugo@empeg.com>
+ * 
+ * 2000/03/29 (C) Nicolas Pitre <nico@cam.org>
+ *	Rewritten: big cleanup, much simpler, better HZ acuracy.
+ *
+ * 2001/02/20 (C) RidgeRun, Inc (http://www.ridgerun.com)
+ *
+ */
+#ifndef __ASM_ARCH_TIME_H__
+#define __ASM_ARCH_TIME_H__
+
+#include <asm/uaccess.h>
+#include <asm/io.h>
+#include <asm/irq.h>
+#include <asm/hardware.h>
+
+extern struct irqaction timer_irq;
+
+extern unsigned long av3xx_gettimeoffset(void);
+extern void av3xx_timer_interrupt(int irq, void *dev_id, struct pt_regs *regs);
+
+void __inline__ setup_timer (void)
+{
+ /* disable */
+	outw(0, AV3XX_TIMER0_BASE+AV3XX_TIMER_MODE);
+	outw(0, AV3XX_TIMER1_BASE+AV3XX_TIMER_MODE);
+	outw(0, AV3XX_TIMER2_BASE+AV3XX_TIMER_MODE);
+	outw(0, AV3XX_TIMER3_BASE+AV3XX_TIMER_MODE);
+
+	/*
+	 * System clock formula:
+	 *         freq = clock / (div * scale)
+	 * Where:
+	 *         clock = 27MHz
+	 *         div   = 27,000
+	 *         scale = 10
+	 *
+	 * Which gives us 100Hz, as desired.
+	 */
+
+	/* 27MHz clock (not ARM clock) */
+	outw(1, AV3XX_TIMER0_BASE+AV3XX_TIMER_SEL);
+
+	/* prescale 10 */
+	outw(9, AV3XX_TIMER0_BASE+AV3XX_TIMER_SCAL);
+
+	/* div 27000 */
+	outw(26999, AV3XX_TIMER0_BASE+AV3XX_TIMER_DIV);
+
+	/* periodic */
+	outw(2, AV3XX_TIMER0_BASE+AV3XX_TIMER_MODE);
+
+
+	gettimeoffset = av3xx_gettimeoffset;
+	timer_irq.handler = av3xx_timer_interrupt;
+	setup_arm_irq(IRQ_TIMER, &timer_irq);
+
+}
+
+
+#endif /* __ASM_ARCH_TIME_H__ */
