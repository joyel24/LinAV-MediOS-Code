+#define RS_STROBE_TIME (10*HZ)
+static struct timer_list serial_timer;
+static SERIAL_AV3XX_INLINE void rs_start_timer(int val)
+{
+	mod_timer(&serial_timer, jiffies + val);
+}
+static SERIAL_AV3XX_INLINE void rs_del_timer()
+{
+	del_timer_sync(&serial_timer);
+}
+static void rs_timer(unsigned long dummy)
+{
+	/* Don't need this, and it muddies the waters while debugging.
+	 * --gmcnutt
+	 */
+	static unsigned long last_strobe;
+	struct av3xx_async_struct *info;
+	unsigned int	i;
+	unsigned long flags;
+
+	if ((jiffies - last_strobe) >= RS_STROBE_TIME) {
+		for (i=0; i < NR_IRQS; i++) {
+			info = IRQ_ports[i];
+			if (!info)
+				continue;
+			save_flags(flags); cli();
+				rs_interrupt_single(i, NULL, NULL);
+			restore_flags(flags);
+		}
+	}
+	last_strobe = jiffies;
+	rs_start_timer(RS_STROBE_TIME);
+
+	if (IRQ_ports[0]) {
+		save_flags(flags); cli();
+		rs_interrupt_single(0, NULL, NULL);
+  		restore_flags(flags);
+		rs_start_timer(IRQ_timeout[0]);
+	}
+}
+static SERIAL_AV3XX_INLINE void rs_init_timer()
+{
+	init_timer(&serial_timer);
+	serial_timer.function = rs_timer;
+	rs_start_timer(RS_STROBE_TIME);
+}
+#else
+#define rs_start_timer(val)
+#define rs_init_timer()
+#define rs_del_timer()
+#endif/* CONFIG_SERIAL_AV3XX_TIMER  *****************************************/
+/*
+ * This routine figures out the correct timeout for a particular IRQ.
+ * It uses the smallest timeout of all of the serial ports in a
+ * particular interrupt chain.  Now only used for IRQ 0....
+ */
+static void figure_IRQ_timeout(int irq)
+{
+	struct	av3xx_async_struct	*info;
+	int	timeout = 60*HZ;	/* 60 seconds === a long time :-) */
+
+	info = IRQ_ports[irq];
+	if (!info) {
+		IRQ_timeout[irq] = 60*HZ;
+		return;
+	}
+	while (info) {
+		if (info->timeout < timeout)
+			timeout = info->timeout;
+		info = info->next_port;
+	}
+	if (!irq)
+		timeout = timeout / 2;
+	IRQ_timeout[irq] = (timeout > 3) ? timeout-2 : 1;
+}
