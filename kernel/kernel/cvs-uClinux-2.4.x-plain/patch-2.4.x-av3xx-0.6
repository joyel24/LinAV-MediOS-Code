+
+#ifndef __ASM_ARCH_IRQ_H__
+#define __ASM_ARCH_IRQ_H__
+
+#include <asm/hardware.h>
+#include <asm/io.h>
+#include <asm/mach/irq.h>
+#include <asm/arch/irqs.h>
+
+#define fixup_irq(x) (x)
+
+extern void av3xx_mask_irq(unsigned int irq);
+extern void av3xx_unmask_irq(unsigned int irq);
+extern void av3xx_mask_ack_irq(unsigned int irq);
+extern void av3xx_init_irq(void);
+
+static __inline__ void irq_init_irq(void)
+{
+	int irq;
+
+	for (irq = 0; irq < NR_IRQS; irq++) {
+		irq_desc[irq].valid	= 1;
+		irq_desc[irq].probe_ok	= 1;
+		irq_desc[irq].mask_ack	= av3xx_mask_ack_irq;
+		irq_desc[irq].mask	= av3xx_mask_irq;
+		irq_desc[irq].unmask	= av3xx_unmask_irq;
+	}
+
+	av3xx_init_irq();
+}
+
+#endif /* __ASM_ARCH_IRQ_H__ */
