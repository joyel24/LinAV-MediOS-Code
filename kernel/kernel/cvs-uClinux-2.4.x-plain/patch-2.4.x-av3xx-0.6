+static SERIAL_AV3XX_INLINE void serial_av3xx_disable_tx_int(struct av3xx_async_struct *info)
+{
+	info->MSR &= ~UART_MSR_TFTIE;
+	serial_out(info, UART_MSR, info->MSR);
+}
+
+static SERIAL_AV3XX_INLINE void serial_av3xx_disable_rx_int(struct av3xx_async_struct *info)
+{
+	info->MSR &= ~UART_MSR_RFTIE;
+	serial_out(info, UART_MSR, info->MSR);
+}
+
+static SERIAL_AV3XX_INLINE void serial_av3xx_enable_tx_int(struct av3xx_async_struct *info)
+{
+	info->MSR |= UART_MSR_TFTIE;
+	serial_out(info, UART_MSR, info->MSR);
+}
+
+static SERIAL_AV3XX_INLINE void serial_av3xx_enable_rx_int(struct av3xx_async_struct *info)
+{
+	info->MSR |= UART_MSR_RFTIE;
+	serial_out(info, UART_MSR, info->MSR);
+}
+
+static SERIAL_AV3XX_INLINE void serial_av3xx_disable_ints(struct av3xx_async_struct *info,
+					     u16 *msr)
+{
+	*msr = info->MSR & UART_MSR_INTS;
+	info->MSR &= ~UART_MSR_INTS;
+	serial_out(info, UART_MSR, info->MSR);
+}
+
+static SERIAL_AV3XX_INLINE void serial_av3xx_restore_ints(struct av3xx_async_struct *info,
+					     u16 msr)
+{
+	info->MSR |= msr & UART_MSR_INTS;
+	serial_out(info, UART_MSR, info->MSR);
+}
+
+static SERIAL_AV3XX_INLINE void serial_av3xx_clear_fifos(struct av3xx_async_struct *info)
+{
+	serial_out(info, UART_RFCR, 0x8000);
+	serial_out(info, UART_TFCR, 0x8000);
+}
