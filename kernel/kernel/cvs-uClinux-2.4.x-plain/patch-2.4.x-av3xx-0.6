+static SERIAL_AV3XX_INLINE unsigned int serial_in(struct av3xx_async_struct *info, 
+					 int offset)
+{
+	return inw(info->iomem_base + (offset<<info->iomem_reg_shift));
+}
+
+static SERIAL_AV3XX_INLINE void serial_out(struct av3xx_async_struct *info, int offset,
+				  int value)
+{
+	outw(value, (unsigned long) info->iomem_base +
+	     (offset<<info->iomem_reg_shift));
+}
