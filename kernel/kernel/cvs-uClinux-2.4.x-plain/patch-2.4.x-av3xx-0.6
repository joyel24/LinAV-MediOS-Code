+
+#include <asm/arch/av3xx_osd.h>
+#include <asm/arch/av3xx_graphics.h>
+#include <asm/arch/av3xx_term.h>
+
+extern char *std6x9_[];
+static struct graphicsBuffer screenBitmap2;
+static int pal32[2] = {0x6c706c93, 0xffffffff};
+static int pal16[2] = {0x0000, 0xffff};
+static struct graphicsBuffer sprite6_9 = {0, 1, 6, 9, 1, 0, -1, 0, 0, 0, 0, (int**) &pal16, (int**) &pal32};
+static unsigned int buff[320*240];
+
+static int fontW               =   6;
+static int fontH               =   9;
+
+static int termW               =   52;
+static int termH               =   26;
+
+static int termX               =   0;
+static int termY               =   0;
+static int terminalColorF      =   0xffff;
+static int terminalColorB      =   0x0000;
+
+void termIni()
+{
+	osdInit();
+
+	osdSetComponentConfig(AV3XX_OSD_VIDEO1, 0);
+    osdSetComponentConfig(AV3XX_OSD_VIDEO2, 0);
+    osdSetComponentConfig(AV3XX_OSD_BITMAP1, 0);
+    osdSetComponentConfig(AV3XX_OSD_BITMAP2, 0);
+    osdSetComponentConfig(AV3XX_OSD_CURSOR1, 0);
+    osdSetComponentConfig(AV3XX_OSD_CURSOR2, 0);
+
+	int j;
+	for (j=0;j<240*320;j++)
+        buff[j]=0x00800080;
+
+	screenBitmap2.offset = (int)buff;
+    screenBitmap2.bytesPerLine = 320*4;
+    screenBitmap2.width = 320;
+    screenBitmap2.height =240;
+    screenBitmap2.bitsPerPixelShift = 5;
+    screenBitmap2.bitsPerPixel = 32;
+
+	osdSetComponentSize(AV3XX_OSD_VIDEO1, 320*2, 240);
+    osdSetComponentPosition(AV3XX_OSD_VIDEO1, 0x14, 0x12);
+    osdSetComponentOffset(AV3XX_OSD_VIDEO1, (int)buff);
+    osdSetComponentSourceWidth(AV3XX_OSD_VIDEO1, 0x28);
+    osdSetComponentConfig(AV3XX_OSD_VIDEO1, AV3XX_OSD_COMPONENT_ENABLE);
+}
+
+void addLine()
+{
+	termX=0;
+	termY++;
+	if(termY > (termH-1))
+	{
+		termY--;
+		graphicsScrollUP(&screenBitmap2,fontH);
+	}
+}
+
+void termPutch(char ch)
+{
+	if(ch=='\r' || ch=='\n')
+	{
+		addLine();
+	}
+	else
+	{
+		graphicsChar(&screenBitmap2, termX*fontW, termY*fontH, &sprite6_9, std6x9_, ch);
+		termX++;
+		if(termX > termW)
+			addLine();
+	}
+
+}
+
+void termPutString(char * s)
+{
+	while(*s)
+	{
+		termPutch(*s);
+		s++;
+	}
+}
