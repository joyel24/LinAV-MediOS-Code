diff --unified --recursive --new-file uClinux-2.4.x/include/asm-armnommu/arch-av3xx/time.h uClinux-2.4.x-av3xx/include/asm-armnommu/arch-av3xx/time.h
--- uClinux-2.4.x/include/asm-armnommu/arch-av3xx/time.h	1970-01-01 00:00:00.000000000 +0000
