+
+/* This defines the initializer for a struct serial_state describing the
+ * TI TMS320AV3XX serial port 0.
+ */
+
+#define AV3XX_SERIAL_PORT0_DEFN \
+  {  \
+    magic:          0, \
+    port:           0, \
+    flags:          STD_COM_FLAGS, \
+    xmit_fifo_size: AV3XX_UART_TXFIFO_BYTESIZE, \
+    baud_base:      BASE_BAUD, \
+    irq:            AV3XX_IRQ_UART0, \
+    type:           PORT_UNKNOWN, \
+    line:           0, \
+    iomem_base:     AV3XX_UART0_BASE, \
+    io_type:        SERIAL_IO_MEM \
+  }
+
+/* This defines the initializer for a struct serial_state describing the
+ * TI TMS320AV3XX serial port 1.
+ */
+
+#define AV3XX_SERIAL_PORT1_DEFN \
+  {  \
+    magic:          0, \
+    port:           0, \
+    flags:          STD_COM_FLAGS, \
+    xmit_fifo_size: AV3XX_UART_TXFIFO_BYTESIZE, \
+    baud_base:      BASE_BAUD, \
+    irq:            AV3XX_IRQ_UART1, \
