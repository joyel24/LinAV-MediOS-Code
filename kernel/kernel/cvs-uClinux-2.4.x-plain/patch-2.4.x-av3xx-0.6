+/* rs_stop() and rs_start()
+ *
+ * These routines are called before setting or resetting tty->stopped.
+ * They enable or disable transmitter interrupts, as necessary.
+ */
+
+static void rs_stop(struct tty_struct *tty)
+{
+	av3xx_async_t *info = (av3xx_async_t *)tty->driver_data;
+	unsigned long flags;
+
+	if (serial_paranoia_check(info, tty->device, "rs_stop")) {
+		return;
+	}
+
+	save_flags(flags); cli();
+	if (info->msr & AV3XX_UART_MSR_TFTIE) {
+		serial_disable_tx_int(info);
+	}
+	restore_flags(flags);
+}
+
+static void rs_start(struct tty_struct *tty)
+{
+	av3xx_async_t *info = (av3xx_async_t *)tty->driver_data;
+	unsigned long flags;
+
+	if (serial_paranoia_check(info, tty->device, "rs_start")) {
+		return;
+	}
+        
+	save_flags(flags); cli();
+
+	if ((info->xmit.head != info->xmit.tail) && (info->xmit.buf) &&
+			!(info->msr & AV3XX_UART_MSR_TFTIE)) {
+		serial_enable_tx_int(info);
+	}
+
+	restore_flags(flags);
+}
