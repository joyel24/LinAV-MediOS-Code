+static inline void serial_disable_tx_int(av3xx_async_t *info)
+{
+	info->msr &= ~AV3XX_UART_MSR_TFTIE;
+	serial_out(info, AV3XX_UART_MSR, info->msr);
+}
+
+static inline void serial_disable_rx_int(av3xx_async_t *info)
+{
+	info->msr &= ~(AV3XX_UART_MSR_TOIC_MASK | AV3XX_UART_MSR_REIE |
+			AV3XX_UART_MSR_RFTIE);
+	serial_out(info, AV3XX_UART_MSR, info->msr);
+}
+
+static inline void serial_enable_tx_int(av3xx_async_t *info)
+{
+	info->msr |= AV3XX_UART_MSR_TFTIE;
+	serial_out(info, AV3XX_UART_MSR, info->msr);
+}
+
+static inline void serial_enable_rx_int(av3xx_async_t *info)
+{
+	info->msr = (info->msr & ~AV3XX_UART_MSR_TOIC_MASK) |
+			(AV3XX_UART_MSR_TIMEOUT_7 | AV3XX_UART_MSR_REIE |
+			 AV3XX_UART_MSR_RFTIE);
+	serial_out(info, AV3XX_UART_MSR, info->msr);
+}
+
+static inline void serial_disable_ints(av3xx_async_t *info, unsigned short *msr)
+{
+	*msr = info->msr & (AV3XX_UART_MSR_TOIC_MASK | AV3XX_UART_MSR_REIE |
+			AV3XX_UART_MSR_TFTIE | AV3XX_UART_MSR_RFTIE);
+	info->msr &= ~(AV3XX_UART_MSR_TOIC_MASK | AV3XX_UART_MSR_REIE |
+			AV3XX_UART_MSR_TFTIE | AV3XX_UART_MSR_RFTIE);
+	serial_out(info, AV3XX_UART_MSR, info->msr);
+}
+
+static inline void serial_restore_ints(av3xx_async_t *info, unsigned short msr)
+{
+	info->msr = (info->msr & ~(AV3XX_UART_MSR_TOIC_MASK | AV3XX_UART_MSR_REIE |
+			AV3XX_UART_MSR_TFTIE | AV3XX_UART_MSR_RFTIE)) |
+			(msr & (AV3XX_UART_MSR_TOIC_MASK | AV3XX_UART_MSR_REIE |
+			AV3XX_UART_MSR_TFTIE | AV3XX_UART_MSR_RFTIE));
+	serial_out(info, AV3XX_UART_MSR, info->msr);
+}
