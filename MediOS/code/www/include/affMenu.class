<?
	class affMenu {

		var $item,$menuOpen,$firstItem,$taille;

		function affMenu($taille=-1)
		{
			$this->menuOpen=false;
			$this->firstItem=true;
			$this->taille=$taille;
		}

		function debItem($titre)
		{
			if($this->menuOpen)
				$this->item->fin();
			if(!$this->firstItem)
			{
				echo "<table height='8' border='0' cellpadding='0' cellspacing='0'>\n";
				echo "<tr><td></td></tr>\n";
				echo "</table>\n";
			}
			else
				$this->firstItem=false;
			$this->item=new affBlock($titre,$this->taille);
			$this->menuOpen=true;
			echo "<div id='menu'>\n";
		}

		function finItem()
		{
			echo "</div>\n";
			$this->item->fin();
			$this->menuOpen=false;
		}

		function addLien($intitule,$url,$target="")
		{
			if(!$this->menuOpen)
			{
				$this->item=new affBlock("");
				$this->menuOpen=true;
			}

			if($target!="")
				$target=" target='".$target."' ";

			echo "<a class='menuMain' href='$url' $target>$intitule</a><br>\n";
		}

		function addLienExt($intitule,$url,$target="")
		{
			if($this->menuOpen)
			{
				$this->item->fin;
				$this->menuOpen=false;
			}

			if(!$this->firstItem)
			{
				echo "<table height='8' border='0' cellpadding='0' cellspacing='0'>\n";
				echo "<tr><td></td></tr>\n";
				echo "</table>\n";
			}
			else
				$this->firstItem=false;

			if($target!="")
				$target=" target='".$target."' ";

			echo "<a class='menuMain' href='$url' $target>$intitule</a><br>\n";
		}

		function ligneVide()
		{
			if(!$this->menuOpen)
			{
				$this->item=new affBlock("");
				$this->menuOpen=true;
			}

			echo "<br>\n";
		}

		function fin()
		{
			if($this->menuOpen)
				$this->item->fin();
		}
	}
?>
