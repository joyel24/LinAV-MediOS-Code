subdirs:        
	@@for p in $(SUBDIRS); do \
		echo '-----   building ' $$p; \
		make -C $$p --no-print-directory -s all; \
	done

clean-subdirs:
	@@for p in $(SUBDIRS); do \
		echo '-----   cleaning ' $$p; \
		make -C $$p --no-print-directory clean; \
	done

.c.o:
	@echo "[$@]"
	@$(GCC) $(GCCFLAGS) -c -o $@ $<
