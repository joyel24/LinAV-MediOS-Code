	class affPage
	{
		var $page,$open;

		function affPage($titre,$page,$align="top",$taille=0)
		{

			$this->page=$page;
			$this->taille=$taille;
			$this->open=true;

		// <strong>L</strong>e groupement des diplŰmťs de l'<strong>INPG</strong> expatriťs hors de<strong>F</strong>rance<p>
