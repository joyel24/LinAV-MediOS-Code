			{
				echo "<table height='".$this->taille."'>\n"
					. "<tr >\n"
					. "<td valign='$align'>\n";
			}
		}

		function closePage($from)
		{
			if($this->open)
			{
				if($from=="fin")
					$tHeight=520;
				else
					$tHeight=500;

				if($this->taille != 0)
				{
					echo "</td>\n"
						. "</tr>\n"
						. "</table>\n";
				}
?>
		</td>
		<td width='4'>&nbsp;</td>
		<td width="2" bgcolor="#000000"></td>
<?
				if($this->taille == 0)
					echo "<td valign='top' height='$tHeight'>\n";
				else
					echo "<td valign='top'>\n";

?>
			<div align="center">
				<font color="#6899DB" size="+1" face="Arial, Helvetica, sans-serif">
<?
				$this->mkPage();
				echo "<strong>$this->page</strong>";
?>
				</font>
			</div>
		</td>
		</tr>
<?
				$this->open=false;
			}
		}

		function basPage($txt)
		{
			if($this->open)
			{
				$this->closePage("bas");
?>
		<tr>
