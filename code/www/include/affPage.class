		function fin()
		{
			$this->closePage("fin");
?>
		</table>
<?
		}

		function mkPage()
		{
			$taille=strlen($this->page);
			$txt="";
			for($i=0;$i<$taille;$i++)
				$txt.=strtoupper($this->page[$i]) . "<br>\n";
			$this->page=$txt;
		}

	}
}
