#include <api.h>
#include <kernel/swi.h>
#include <kernel/errors.h>

#define swi_call(SWI_NUM)                \
    ({                                   \
        register long _r0 asm("r0");     \
        asm volatile(                    \
            "stmdb sp!, {r3-r5} \n"     \
            "swi %0\n"                   \
            "ldmia sp!, {r3-r5}"        \
        :                                \
        : "i"(SWI_NUM)                   \
        : "memory");                     \
        return (long) _r0;               \
    })    

unsigned int api_getFctPtr(char * name)    { swi_call(nAPI_INIAPI); }

