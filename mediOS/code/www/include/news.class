<?
	class dispItem {

		var $opened,$affNews;

		function dispItem()
		{
			$this->affNews= new affBlock("News");
			$this->opened=true;
			echo "<table border='0' width='95%'>\n";
		}

		function addItem($txt)
		{
			if($this->opened)
			{
				echo "<tr>\n<td>\n$txt\n</td>\n</tr>\n";
			}
		}

		function endDisp()
		{
			if($this->opened)
			{
				echo "</table>\n";
				$this->affNews->fin();
			}
		}
	}
?>